# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Database (Prisma) — Supabase / Postgres ---
# Transaction pooler (port 6543). Encode special chars in password: # → %23, $ → %24, @ → %40
DATABASE_URL="postgresql://USER:ENCODED_PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# Session / direct (port 5432) — required for prisma migrate. Copy "Session mode" URI from Supabase → Connect.
DIRECT_URL="postgresql://USER:ENCODED_PASSWORD@HOST.pooler.supabase.com:5432/postgres?sslmode=require"

# --- Admin panel (/admin) — set strong values in production ---
# Minimum 8 characters.
ADMIN_PASSWORD="change-this-password"
# Minimum 16 characters; use a long random string.
ADMIN_SESSION_SECRET="change-this-to-a-long-random-secret-string"

# --- Cloudinary (optional — admin image upload for services) ---
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# --- SMTP (used by POST /api/admin/mail and optional enquiry notifications) ---
# Port 587 + SMTP_SECURE=false is typical (STARTTLS). Port 465 often uses SMTP_SECURE=true.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
TLS_ENABLED="true"
SMTP_USER="kaverikhode2706@gmail.com"
SMTP_PASSWORD="vjgv xkkd cdpb ufbz"
SMTP_FROM="Karan Engineers <noreply@yourdomain.com>"
# Default recipient when API body omits "to"
ENQUIRY_TO_EMAIL="kaverikhode2706@gmail.com"

# Optional: default URL for <DynamicPage /> client fetch (same-origin or absolute)
# NEXT_PUBLIC_PAGE_SECTIONS_API_URL="/api/page-sections"
